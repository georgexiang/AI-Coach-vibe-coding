# App
APP_NAME=AI Coach Platform
DEBUG=false
API_PREFIX=/api/v1

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./ai_coach.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ai_coach

# JWT Auth
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Feature Toggles
FEATURE_AVATAR_ENABLED=false
FEATURE_VOICE_ENABLED=false
FEATURE_REALTIME_VOICE_ENABLED=false
FEATURE_CONFERENCE_ENABLED=false

# Voice Mode: text_only | stt_tts | realtime | voice_live
DEFAULT_VOICE_MODE=text_only

# Region: global | china | eu
REGION=global

# AI Service Providers (default to mock for local dev)
DEFAULT_LLM_PROVIDER=mock
DEFAULT_STT_PROVIDER=mock
DEFAULT_TTS_PROVIDER=mock
DEFAULT_AVATAR_PROVIDER=mock

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Azure Speech (STT/TTS)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Azure Avatar
AZURE_AVATAR_ENDPOINT=
AZURE_AVATAR_KEY=

# Azure Content Understanding
AZURE_CONTENT_ENDPOINT=
AZURE_CONTENT_KEY=

# Other AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
